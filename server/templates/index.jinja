{%extends "base.jinja"%}
{% block head %}
<title>Vote!</title>
{% endblock %}

{% block body %}
<h1>Pick your Favourite Scripts!</h1>
{% if message != " "%}
<h3>{{message}}</h3>
{% endif %}

<form action="/vote" method="post">
    <label for="name">Name:</label> <input type="text" name="name" placeholder="Your Name" value="{{ name }}" required><br>
    <label for="filter">Search:</label> <input type="text" name="filter" placeholder="Search..." oninput="filter_options(this.value);"><br><br>

    {% for script_set in available_scripts %}
    <label name="script" value="{{ script_set }}">
        <input type="checkbox" name="script_checkbox" value="{{ script_set }}" {% if script_set in current_votes %}checked{% endif %}>
         {% for script in script_set.split(", ") %}<a href="/scripts/{{script}}" target="_blank">{{ script.replace("_", " ").title() }}</a> {% endfor %}
        <br>
    </label>
    {% endfor %}
    
    <br>

    <input type="submit" value="Cast Vote!">
</form>

<h3>See the results <a href="/results">here!</a></h3>
<script src="/static/js/filter.js"></script>
{% endblock %}
