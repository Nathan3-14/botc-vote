{% extends "base.jinja" %}

{% block title %}Results{% endblock %}

{% block body %}
{% if votes|length == 0 %}
<h3>No Votes have been Cast</h3>
{% endif %}
<ol>
{% for script_set, vote_count in votes.items()%}
    <li>
        {% for script in script_set.split(", ") %}<a href="/scripts/{{script}}" target="_blank">{{ script.replace("_", " ").title() }}</a> {% endfor %}
        : {{ vote_count }}
    </li>
{% endfor %}
</ol>
{% endblock %}
