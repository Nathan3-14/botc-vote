{% extends "base.jinja" %}

{% block head %}
<title>Results</title>
{% endblock %}

{% block body %}
<h1>Results</h1>
<h3>{{message}}</h3>
<ol>
{% for script_set, vote_count in votes.items()%}
    <li>
        {% for script in script_set.split(", ") %}<a href="/scripts/{{script}}" target="_blank">{{ script.replace("_", " ").title() }}</a> {% endfor %}
        : {{ vote_count }}
    </li>
{% endfor %}
</ol>
{% endblock %}
