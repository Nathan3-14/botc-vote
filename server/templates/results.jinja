{% extends "base.jinja" %}
{% block head %}
<title>Results</title>
{% endblock %}

{% block body %}
<h1>Results</h1>
<h3><a href="/">Back</a></h3>
<ol>
{% for script_set, vote_count in votes.items()%}
    <li>
        {{['<a href="/scripts/{{script}}">{{ script.replace("_", " ").title() }}</a>' for script in script_set.split(", ")].join(", ")}}
        : {{ vote_count }}
    </li>
{% endfor %}
</ol>
{% endblock %}